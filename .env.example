# Bike Doc local development environment.
# Copy this file to .env at the repository root before running Docker Compose.

# FastAPI application title.
BIKE_DOC_API_APP_NAME="Bike Doc API"

# Runtime environment name, such as local, test, or production.
BIKE_DOC_API_ENVIRONMENT=local

# FastAPI debug mode.
BIKE_DOC_API_DEBUG=true

# JSON list of local/development browser origins allowed by CORS.
BIKE_DOC_API_CORS_ORIGINS='["http://localhost:3000","http://localhost:8080"]'

# Optional stdlib logging level override, such as DEBUG, INFO, WARNING, or ERROR.
BIKE_DOC_API_LOG_LEVEL=

# Optional logging renderer override: console or json.
BIKE_DOC_API_LOG_FORMAT=

# Local Docker Compose host port for the API service.
BIKE_DOC_API_PORT=8000

# Local Docker Compose Postgres container settings.
POSTGRES_USER=bikedoc
POSTGRES_PASSWORD=bikedoc
POSTGRES_DB=bikedoc
POSTGRES_PORT=5432
