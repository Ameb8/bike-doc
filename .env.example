# Bike Doc local development environment.
# Copy this file to .env at the repository root before running Docker Compose.

# FastAPI application title.
BIKE_DOC_API_APP_NAME="Bike Doc API"

# Runtime environment name, such as local, test, or production.
BIKE_DOC_API_ENVIRONMENT=local

# FastAPI debug mode.
BIKE_DOC_API_DEBUG=true

# JSON list of local/development browser origins allowed by CORS.
BIKE_DOC_API_CORS_ORIGINS='["http://localhost:3000","http://localhost:8080"]'

# SQLAlchemy async database URL used by the API and Alembic.
BIKE_DOC_API_DATABASE_URL=postgresql+asyncpg://bikedoc:bikedoc@db:5432/bikedoc

# Local fixed-token auth mode. Do not use dev mode in production.
BIKE_DOC_API_AUTH_MODE=dev
BIKE_DOC_API_DEV_AUTH_TOKEN=dev-token
BIKE_DOC_API_DEV_AUTH_SUBJECT=dev-user
BIKE_DOC_API_DEV_AUTH_EMAIL=dev@example.com
BIKE_DOC_API_DEV_AUTH_DISPLAY_NAME="Dev User"

# Optional stdlib logging level override, such as DEBUG, INFO, WARNING, or ERROR.
BIKE_DOC_API_LOG_LEVEL=

# Optional logging renderer override: console or json.
BIKE_DOC_API_LOG_FORMAT=

# Artifact uploads use local storage for this implementation slice.
BIKE_DOC_API_ARTIFACT_STORAGE_PROVIDER=local
BIKE_DOC_API_ARTIFACT_LOCAL_STORAGE_ROOT=apps/api/.local/artifacts
BIKE_DOC_API_ARTIFACT_MAX_UPLOAD_BYTES=10485760

# Diagnostic LLM runtime provider: google_ai or vertex_ai.
BIKE_DOC_API_DIAGNOSTIC_LLM_PROVIDER=google_ai

# Gemini model and generation settings used by the internal diagnostic ADK agent.
BIKE_DOC_API_DIAGNOSTIC_AGENT_MODEL=gemini-2.5-flash
BIKE_DOC_API_DIAGNOSTIC_AGENT_TEMPERATURE=0.2
BIKE_DOC_API_DIAGNOSTIC_AGENT_MAX_OUTPUT_TOKENS=2048
BIKE_DOC_API_DIAGNOSTIC_AGENT_TIMEOUT_SECONDS=30

# Google AI provider credentials. Set one when DIAGNOSTIC_LLM_PROVIDER=google_ai.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Vertex AI provider environment. Required when DIAGNOSTIC_LLM_PROVIDER=vertex_ai.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Local Docker Compose host port for the API service.
BIKE_DOC_API_PORT=8000

# Local Docker Compose Postgres container settings.
POSTGRES_USER=bikedoc
POSTGRES_PASSWORD=bikedoc
POSTGRES_DB=bikedoc
POSTGRES_PORT=5432
