FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/opt/bike-doc-api-venv \
    UV_LINK_MODE=copy \
    PATH="/opt/bike-doc-api-venv/bin:${PATH}"

WORKDIR /workspace

COPY pyproject.toml uv.lock ./
COPY apps/api/pyproject.toml apps/api/README.md ./apps/api/
RUN cd apps/api && uv sync --frozen --group dev --no-install-project

COPY apps/api ./apps/api
RUN cd apps/api && uv sync --frozen --group dev

EXPOSE 8000

CMD ["uv", "run", "--directory", "/workspace/apps/api", "uvicorn", "bike_doc_api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/workspace/apps/api/src"]
